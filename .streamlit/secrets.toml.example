# Local development secrets. Copy to .streamlit/secrets.toml and fill in.
# In Streamlit Community Cloud, set the same TOML content via App → Settings → Secrets.

OPENAI_API_KEY = "sk-proj-..."

# Optional: enable a password gate. If this is set, the app prompts for a password
# before showing anything. Leave it out (or comment) to keep the app open.
# APP_PASSWORD = "choose-a-strong-password"
